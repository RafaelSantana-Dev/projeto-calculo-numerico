package br.edu.projeto4.service;

import br.edu.projeto4.model.CriterioParada;
import br.edu.projeto4.model.SistemaLinear;
import br.edu.projeto4.model.IteracaoSistemaLinear;
/**
 * Wrapper para o método de Gauss-Seidel que implementa a interface SessaoIterativaLinear.
 * Delegada para MetodoGaussSeidel.
 */
public class SessaoSeidelLinear implements SessaoIterativaLinear {

    private final MetodoGaussSeidel metodo;

    public SessaoSeidelLinear(SistemaLinear sistema, double tolerancia, int maxIteracoes, CriterioParada criterio) {
        this.metodo = new MetodoGaussSeidel(sistema, tolerancia, maxIteracoes, criterio);
    }

    @Override
    public boolean step() {
        return metodo.step();
    }

    @Override
    public boolean terminou() {
        return metodo.terminou();
    }

    @Override
    public boolean convergiu() {
        return metodo.convergiu();
    }

    @Override
    public int getIteracaoAtual() {
        return metodo.getIteracaoAtual();
    }

    @Override
    public double[] getSolucaoAtual() {
        return metodo.getSolucaoAtual();
    }

    @Override
    public double getErroAtual() {
        return metodo.getErroAtual();
    }

    @Override
    public double getResiduoAtual() {
        return metodo.getResiduoAtual();
    }

    @Override
    public br.edu.projeto4.model.IteracaoSistemaLinear getIteracaoResultado() {
        return metodo.getIteracaoResultado();
    }

    @Override
    public br.edu.projeto4.model.ResultadoSistemaLinear getResultado() {
        return metodo.getResultado();
    }
}